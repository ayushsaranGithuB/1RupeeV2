{
  "name": "1rupee",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "India's simplest recurring giving platform",
  "scripts": {
    "dev": "next dev -p 8080",
    "build": "next build",
    "start": "next start -p 8080",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "db:push": "drizzle-kit push:pg",
    "db:generate": "drizzle-kit generate:pg",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run db/seed.ts"
  },
  "dependencies": {
    "better-auth": "1.6.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "^0.30.0",
    "hono": "^3.0.0",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "postgres": "^3.4.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-breaks": "4.0.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss-animate": "1.0.7",
    "typescript": "5.9.3",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "11.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^1.0.0",
    "autoprefixer": "10.5.2",
    "drizzle-kit": "^0.20.0",
    "eslint-plugin-react": "latest",
    "eslint-plugin-react-hooks": "latest",
    "jsdom": "^24.0.0",
    "postcss": "8.5.16",
    "tailwindcss": "4.3.2",
    "typescript-eslint": "latest",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "packageManager": "bun@1.3.14"
}
