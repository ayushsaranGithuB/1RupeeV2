{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    // App is bundled by `bun build`; no .d.ts emit. Disabling declaration
    // avoids TS2742 portability errors from Better Auth's zod-v4 inferred types.
    "declaration": false,
    // "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@db": ["../../db"],
      "@db/*": ["../../db/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
